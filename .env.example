# =============================================================================
# QR-Фотограф · env config
# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
# =============================================================================

# --- Public site URL (used for QR generation and absolute URLs) -----------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ------------------------------------------------------------------
# Create a project at https://supabase.com and copy these from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-only key — bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Telegram bot (for lead notifications & couple updates) -------------------
# Create a bot via @BotFather, then get the chat ID by writing to the bot
# and visiting https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_LEAD_CHAT_ID=

# --- SMS (Uzbekistan, via Eskiz) — used by Supabase Auth phone OTP ------------
# Configure inside Supabase Dashboard → Authentication → Phone provider.
# Reference values left here so deployment scripts can sync them.
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=

# --- Storage (optional; default is Supabase Storage) --------------------------
# To use Cloudflare R2 for cheaper egress, set these and switch the storage
# adapter in src/lib/supabase/*.ts.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PHOTOS=event-photos
R2_BUCKET_VIDEOS=event-videos
